{
  "name": "backoffice",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "shared:build": "tsc --build ../shared",
    "dev": "npm run shared:build && vite",
    "build": "npm run shared:build && run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "npm run shared:build && vite build",
    "type-check": "vue-tsc --build",
    "lint": "npm run shared:build && eslint",
    "lint:fix": "npm run shared:build && eslint . --fix"
  },
  "dependencies": {
    "@tm-trialmaple/shared": "file:../shared",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.6.1",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "10.6.2",
    "globals": "^14.0.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5"
  }
}
