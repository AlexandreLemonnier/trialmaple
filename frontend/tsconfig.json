{
  "extends": "../configs/typescript/tsconfig.vue.json",
  "compilerOptions": {
    "outDir": ".output",
    "types": [
      "vite/client",
      "node"
    ],
    "paths": {
      "#/*": [
        "./src/*"
      ]
    }
  },
  "references": [
    {
      "path": "../shared"
    },
    {
      "path": "../configs"
    }
  ],
  "exclude": [
    "build/**",
    ".output/**",
    "node_modules/**",
    "public/**"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.vue",
    "vite.config.ts",
    "*.d.ts"
  ]
}
